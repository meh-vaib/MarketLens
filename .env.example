# =============================================================================
# AI Market Intelligence Agent - environment variables
# Copy this file to `.env` and fill in your own values.
# =============================================================================

# --- LLM provider --------------------------------------------------------------
# One of: anthropic | openai | ollama | groq
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1500

# Local-only (development): Ollama running mistral, llama3, etc.
OLLAMA_BASE_URL=http://localhost:11434

# Cloud (free tier - recommended for GitHub Actions hosting):
# Sign up at https://console.groq.com/ and use a model like
# llama-3.3-70b-versatile or llama-3.1-8b-instant.
GROQ_API_KEY=

# Paid (premium quality):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Email delivery ------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=recipient1@example.com,recipient2@example.com
EMAIL_ENABLED=true

# --- Scheduling (UTC) ----------------------------------------------------------
SCHEDULE_HOUR=7
SCHEDULE_MINUTE=30

# --- Storage -------------------------------------------------------------------
DATABASE_URL=sqlite:///data/intel.db

# --- Pipeline knobs ------------------------------------------------------------
MAX_ITEMS_PER_SOURCE=20
MAX_ITEMS_TO_ANALYZE=25
RELEVANCE_THRESHOLD=0.35
REQUEST_TIMEOUT_SECONDS=15

# --- Optional API keys ---------------------------------------------------------
NEWSAPI_KEY=
FRED_API_KEY=
ALPHAVANTAGE_KEY=

# --- API server ----------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=change-me-to-a-random-string

# --- Logging -------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
